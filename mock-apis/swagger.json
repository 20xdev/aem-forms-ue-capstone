      }
    },
    "/generateEmailOTP": {
      "post": {
        "summary": "Generate Email OTP",
        "description": "Tier 2 – Sends an OTP to the customer's email address for verification on the personal info screen.",
        "tags": ["Tier 2 – Integration"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "contextParam": { "$ref": "#/components/schemas/ContextParam" },
                  "requestString": {
                    "type": "object",
                    "properties": {
                      "emailAddress": { "type": "string", "example": "ankit@gmail.com" },
                      "customerID": { "type": "string", "example": "XXXX124" },
                      "fillerFields": { "$ref": "#/components/schemas/FillerFields" }
                    },
                    "required": ["emailAddress"]
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Email OTP sent successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "contextParam": { "$ref": "#/components/schemas/ContextParam" },
                    "responseString": {
                      "type": "object",
                      "properties": {
                        "otpSent": { "type": "string", "example": "Y" },
                        "maskedEmail": { "type": "string", "example": "an***@gmail.com" }
                      }
                    },
                    "status": { "$ref": "#/components/schemas/ApiStatus" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/validateEmailOTP": {
      "post": {
        "summary": "Validate Email OTP",
        "description": "Tier 2 – Validates the OTP sent to the customer's email address.",
        "tags": ["Tier 2 – Integration"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "contextParam": { "$ref": "#/components/schemas/ContextParam" },
                  "requestString": {
                    "type": "object",
                    "properties": {
                      "emailAddress": { "type": "string", "example": "ankit@gmail.com" },
                      "otpValue": { "type": "string", "example": "123456" },
                      "customerID": { "type": "string", "example": "XXXX124" },
                      "fillerFields": { "$ref": "#/components/schemas/FillerFields" }
                    },
                    "required": ["emailAddress", "otpValue"]
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Email OTP validation result",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "contextParam": { "$ref": "#/components/schemas/ContextParam" },
                    "responseString": {
                      "type": "object",
                      "properties": {
                        "emailVerified": { "type": "string", "example": "Y" }
                      }
                    },
                    "status": { "$ref": "#/components/schemas/ApiStatus" }
                  }
                },
                "examples": {
                  "success": {
                    "summary": "Email OTP valid",
                    "value": {
                      "responseString": { "emailVerified": "Y" },
                      "status": { "responseCode": "0", "errorCode": "", "errorDesc": "" }
                    }
                  },
                  "failure": {
                    "summary": "Email OTP invalid",
                    "value": {
                      "responseString": { "emailVerified": "N" },
                      "status": { "responseCode": "1", "errorCode": "ERR_EMAIL_OTP_001", "errorDesc": "Invalid email OTP" }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/submitLoanApplication": {
      "post": {
        "summary": "Submit Loan Application",
        "description": "Tier 1 & 2 – Final submission of the loan application. Called from the Preview/Review screen. Returns vKYC link and acknowledgement ID.",
        "tags": ["Tier 1 – Foundation", "Tier 2 – Integration"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "contextParam": { "$ref": "#/components/schemas/ContextParam" },
                  "requestString": {
                    "type": "object",
                    "properties": {
                      "loanAmount": { "type": "string", "example": "1500000" },
                      "tenure": { "type": "string", "example": "36" },
                      "rateofInterest": { "type": "string", "example": "10.20%" },
                      "emi": { "type": "string", "example": "48449" },
                      "processingfees": { "type": "string", "example": "3000" },
                      "product": { "type": "string", "example": "PL" },
                      "consentToCALL": { "type": "string", "example": "Y" },
                      "educationalQualification": { "type": "string", "example": "" },
                      "monthlyTakeHomeSalary": { "type": "string", "example": "100000" },
                      "noOfDependent": { "type": "string", "example": "2" },
                      "salesPromotion": { "type": "string", "example": "" },
                      "yearAtCity": { "type": "string", "example": "" },
                      "yearAtCurrentAddress": { "type": "string", "example": "" },
                      "employerName": { "type": "string", "example": "Apollo Services" },
                      "vkycConsent": { "type": "string", "example": "Y" },
                      "vkycRetUrl": { "type": "string", "example": "" },
                      "leadRetUrl": { "type": "string", "example": "" },
                      "flgDropOff": { "type": "string", "example": "" },
                      "fillerFields": { "$ref": "#/components/schemas/FillerFields" }
                    },
                    "required": ["loanAmount", "tenure", "rateofInterest", "emi"]
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Loan application submitted successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "contextParam": { "$ref": "#/components/schemas/ContextParam" },
                    "responseString": {
                      "type": "object",
                      "properties": {
                        "vkycLink": { "type": "string", "example": "" },
                        "acknowledgementId": { "type": "string", "example": "142356743" }
                      }
                    },
                    "status": { "$ref": "#/components/schemas/ApiStatus" }
                  }
                },
                "examples": {
                  "success": {
                    "summary": "Submission successful",
                    "value": {
                      "contextParam": {
                        "partnerID": "HDFCBANK",
                        "channelID": "ADOBE",
                        "productName": "PL",
                        "partnerJourneyID": "123456",
                        "bankJourneyID": "7890123"
                      },
                      "responseString": {
                        "vkycLink": "",
